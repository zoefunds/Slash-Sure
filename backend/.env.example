# ─── Application ───────────────────────────────────────────────
APP_NAME=SlashSure
APP_ENV=development
SECRET_KEY=CHANGE_ME_USE_openssl_rand_hex_32
DEBUG=true

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://slashsure:slashsure_pass@localhost:5432/slashsure
DATABASE_SYNC_URL=postgresql://slashsure:slashsure_pass@localhost:5432/slashsure

# ─── Redis (Upstash TLS for production) ────────────────────────
REDIS_URL=rediss://default:YOUR_UPSTASH_PASSWORD@YOUR_UPSTASH_HOST.upstash.io:6379

# ─── JWT ───────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_USE_openssl_rand_hex_64
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Wallet Encryption ─────────────────────────────────────────
WALLET_MASTER_KEY=CHANGE_ME_USE_openssl_rand_hex_32

# ─── GenLayer ──────────────────────────────────────────────────
GENLAYER_RPC_URL=https://studio.genlayer.com/api
GENLAYER_CONTRACT_ADDRESS=0x444250D147c58a19f4e8CA43527e37F327441eF8
GENLAYER_DEPLOYER_PRIVATE_KEY=

# ─── Brevo Email ───────────────────────────────────────────────
BREVO_API_KEY=YOUR_BREVO_API_KEY
BREVO_SENDER_EMAIL=your-verified-sender@example.com
BREVO_SENDER_NAME=SlashSure
FRONTEND_URL=https://slash-sure.vercel.app

# ─── Slack ─────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=#slashsure-alerts

# ─── Network RPC Endpoints ─────────────────────────────────────
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
BEACON_API_URL=https://beaconcha.in/api/v1
COSMOS_RPC_URL=https://rpc.cosmos.network
BABYLON_RPC_URL=https://rpc.babylonchain.io

# ─── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://slash-sure.vercel.app

# ─── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ─── Webhooks ──────────────────────────────────────────────────
WEBHOOK_SECRET=CHANGE_ME_USE_openssl_rand_hex_32
